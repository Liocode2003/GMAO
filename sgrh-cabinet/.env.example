# ============================================================
# SGRH Cabinet — Variables d'environnement
# Copiez ce fichier en .env et complétez les valeurs
# ============================================================

# ──────────────────────────────────────────────────────────
# Base de données PostgreSQL
# ──────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sgrh_cabinet
DB_USER=sgrh_user
DB_PASSWORD=sgrh_secure_pass_change_this_in_prod

# ──────────────────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────────────────
# IMPORTANT: Générez une clé aléatoire forte (min 32 caractères)
# Commande: openssl rand -base64 48
JWT_SECRET=CHANGEZ_MOI_openssl_rand_base64_48
JWT_EXPIRES_IN=1h

# ──────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://votre-domaine.com
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────
# Ports exposés (Docker)
# ──────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ──────────────────────────────────────────────────────────
# Configuration SMTP (emails automatiques)
# ──────────────────────────────────────────────────────────
# Pour Gmail: activer "Mots de passe d'application" dans le compte Google
# Pour Zoho/OVH: utiliser les paramètres SMTP fournis par l'hébergeur

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM="SGRH Cabinet <noreply@cabinet.ci>"

# Exemple OVH:
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contact@votre-domaine.com
# SMTP_PASS=votre_mdp_email
